# 服务配置
PORT=8002
HOST=0.0.0.0

# API Key配置
API_KEYS=kb-api-key-123,kb-api-key-456

# 数据库配置
DATABASE_URL=sqlite:///./kb.db

# 文件存储配置
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=52428800

# 嵌入模型配置
DEFAULT_EMBEDDING_MODEL=bge-large-zh
SUPPORTED_MODELS=bge-large-zh,text-embedding-ada

# 向量检索配置
VECTOR_STORE=faiss
TOP_K=5
CHUNK_SIZE=512
CHUNK_OVERLAP=50

# 日志配置
LOG_LEVEL=INFO
