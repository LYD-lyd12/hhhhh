# 服务配置
PORT=8001
HOST=0.0.0.0

# 数据库配置
DATABASE_URL=sqlite:///./skills.db
# PostgreSQL示例: postgresql://user:password@localhost/dbname
# MySQL示例: mysql+pymysql://user:password@localhost/dbname

# API Key认证（多个用逗号分隔）
API_KEYS=skill-admin-key-123,skill-user-key-456

# 文件存储配置
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# 日志配置
LOG_LEVEL=INFO
